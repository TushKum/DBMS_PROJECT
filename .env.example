# TiDB Cloud Serverless (MySQL) — provision via Vercel Marketplace
# Format: mysql://<user>:<password>@<host>:4000/<database>
DATABASE_URL="mysql://user:password@gateway.region.prod.aws.tidbcloud.com:4000/stockflix"
DATABASE_SSL="true"

# Upstash Redis — provision via Vercel Marketplace
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Vercel Blob — auto-injected when integration is added
BLOB_READ_WRITE_TOKEN=""

# Optional staff identifier for Movement audit trail (no auth in v1)
NEXT_PUBLIC_DEFAULT_STAFF_ID="1"
